# Loaded automatically by `just` (see repo Justfile: set dotenv-load).
# Shell exports override these values.

# Auth0 `sub` claim — seeded stations are owned by this user id.
PREPROV_USER_ID=local-dev-user

# Jib image tag for local docker-compose (default: dev).
# BACKEND_IMAGE_TAG=dev

# Override the full backend image reference if needed.
# BACKEND_IMAGE=markdj/mycelium-backend:dev-20250619-164500
